{
  "name": "Built with Tailwind CSS",
  "description": "Built with Tailwind CSS is a Firefox Extension that identifies the usage of Tailwind CSS in web pages.",
  "version": "2.6.1",
  "manifest_version": 2,
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/built-with-tailwindcss16.png",
      "32": "images/built-with-tailwindcss16.png",
      "128": "images/built-with-tailwindcss128.png"
    }
  },
  "icons": {
    "16": "images/built-with-tailwindcss16.png",
    "32": "images/built-with-tailwindcss16.png",
    "48": "images/built-with-tailwindcss128.png",
    "128": "images/built-with-tailwindcss128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "built-with-tailwind-css@dankoresoft.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
